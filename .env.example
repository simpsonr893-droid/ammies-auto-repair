# GEMINI_API_KEY: Required for Gemini AI API calls.
# Used only by the Node server (server/index.ts) — never bundled into client code.
# On Replit: configure via the Secrets panel. Locally: copy to .env.local.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# PORT: Optional. Defaults to 3000. Replit/most hosts inject this automatically.
# PORT=3000
